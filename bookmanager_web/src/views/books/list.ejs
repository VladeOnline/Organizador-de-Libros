<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { currentUser }) %>

<section class="card">
  <div class="row-between">
    <h1>Mis libros</h1>
    <a class="btn" href="/libros/nuevo">Nuevo libro</a>
  </div>

  <form class="search" method="GET" action="/libros">
    <input
      type="text"
      name="q"
      value="<%= search || '' %>"
      placeholder="Buscar por titulo o autor"
    />
    <button type="submit" class="btn">Buscar</button>
  </form>

  <% if (!books.length) { %>
  <p>No hay libros registrados todavia.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Titulo</th>
          <th>Autor</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach((book) => { %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.author %></td>
          <td><span class="badge"><%= book.readingStatus %></span></td>
          <td>
            <a href="/libros/<%= book._id %>">Ver</a>
            <a href="/libros/<%= book._id %>/editar">Editar</a>
            <form action="/libros/<%= book._id %>/eliminar" method="POST" class="inline-form">
              <button type="submit" class="danger-btn">Eliminar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
